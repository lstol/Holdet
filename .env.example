# .env.example — copy to .env and fill in real values
# NEVER commit .env to git.
#
# How to get HOLDET_COOKIE:
#   1. Chrome → holdet.dk → log in
#   2. F12 → Network → Fetch/XHR
#   3. Navigate to the rider market / your team page
#   4. Find the "players" request → Headers → copy the full Cookie value
#   5. Paste below. Cookie expires periodically — refresh when you get 401/403.

HOLDET_COOKIE=your_session_cookie_here

# Game IDs
HOLDET_GAME_ID=612
HOLDET_GAME_ID_GIRO=612
HOLDET_GAME_ID_TDF=TBC

# Fantasy team
HOLDET_FANTASY_TEAM_ID=your_fantasy_team_id_here
HOLDET_CARTRIDGE=giro-d-italia-2026

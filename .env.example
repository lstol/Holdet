# .env.example — copy to .env and fill in real values
# NEVER commit .env to git.

# Holdet credentials (replaces cookie-based auth)
HOLDET_EMAIL=your_holdet_email@example.com
HOLDET_PASSWORD=your_holdet_password

# Game IDs
HOLDET_GAME_ID=612
HOLDET_GAME_ID_GIRO=612
HOLDET_GAME_ID_TDF=TBC

# Fantasy team
HOLDET_FANTASY_TEAM_ID=your_fantasy_team_id
HOLDET_CARTRIDGE=giro-d-italia-2026

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key

# Anthropic (for Gather Intelligence)
ANTHROPIC_API_KEY=your_anthropic_key
